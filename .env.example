# Briefa environment template
# Copy to .env (gitignored) and fill in secrets.

# ──────────────────────────────────────────────────────────────────
# Gemini (required) — text synthesis + vision OCR
# ──────────────────────────────────────────────────────────────────
# Single key or comma-separated rotation list
GEMINI_API_KEYS=
# Optional alias (some libs read this)
# GOOGLE_API_KEY=

# ──────────────────────────────────────────────────────────────────
# Cloudflare Workers AI (optional) — FLUX image generation
# ──────────────────────────────────────────────────────────────────
# Format: <account_id>:<api_token>,<account_id>:<api_token>,...
# Reuse từ ktb-lingo-feeder / news-editor (5 accounts, ~10k neurons/day each)
CLOUDFLARE_ACCOUNTS=

# ──────────────────────────────────────────────────────────────────
# Pexels (optional) — stock photo fallback
# ──────────────────────────────────────────────────────────────────
# Comma-separated rotation list (200 req/h, 20k/month per key)
PEXELS_API_KEYS=

# ──────────────────────────────────────────────────────────────────
# TTS escape hatch
# ──────────────────────────────────────────────────────────────────
# Set 1 to allow gTTS fallback when Edge TTS fails repeatedly.
# Default 0 → fail-hard (matching news-editor pattern).
BRIEFA_ALLOW_GTTS=0

# ──────────────────────────────────────────────────────────────────
# GitHub (optional) — increases rate limit 60→5000 req/h
# ──────────────────────────────────────────────────────────────────
# Personal access token (read-only public scope is enough)
# GITHUB_TOKEN=
