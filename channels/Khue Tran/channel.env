# ─────────────────────────────────────────────────────────────────────────
# Example VN AI-News channel — copy this to channels/<your-brand>/ and edit.
# This file is parsed as KEY=VALUE pairs (python-dotenv). No quotes needed.
# ─────────────────────────────────────────────────────────────────────────

# ── Identity ──
CHANNEL_NAME=Khuê Trần
CHANNEL_HANDLE=@khuetran.tn
CHANNEL_WATERMARK=

# Optional small round avatar (file under channels/<slug>/static/<name>).
# Leave empty to skip the avatar chip.
AVATAR_FILENAME=

# ── Theme ──
# "dark"   = high-contrast nighttime feel (default)
# "bright" = newspaper editorial feel
THEME_VARIANT=dark
THEME_PRIMARY=#22d3ee
THEME_ACCENT=#4ade80
THEME_BG=#0a0e1a
THEME_HIGHLIGHT=#ef4444
THEME_GOLD=#fbbf24

# ── Voice ──
# Edge TTS vi-VN voice. Pick from:
#   vi-VN-NamMinhNeural  (male, neutral, broadcaster pace — DEFAULT)
#   vi-VN-HoaiMyNeural   (female, warm, drags at any rate)
#
# Upstream news_editor in ktb-studio runs vi-VN-NamMinhNeural at the
# canonical NEWS rate (+35%) and that reads like VTV / HTV. The female
# voice has a natural drag that no rate bump fixes, so it's not the
# right default for news.
VOICE_NAME=vi-VN-NamMinhNeural
VOICE_GENDER=male

# How the renderer picks gender when planner doesn't pin one:
#   channel_default | always_male | always_female | auto_by_topic
# upstream news channel uses auto_by_topic — male by default, switches to
# female on topic keywords involving women / children / lifestyle.
VOICE_GENDER_POLICY=auto_by_topic

# ── Optional premium TTS providers (leave blank = use Edge TTS only) ──
# ELEVENLABS_VOICE_ID=
# GOOGLE_TTS_API_KEY=
# GOOGLE_TTS_VOICE=

# ── Promo outro (showcase mode) ──
# When true, composer appends a 3-5s brand line read at the end.
PROMO_ENABLED=false
PROMO_OUTRO_TEXT=
PROMO_OUTRO_VOICE=vi-VN-NamMinhNeural
# Match body NEWS rate (+35%) — upstream news_editor uses the same value.
PROMO_OUTRO_RATE=+35%

# ── Hashtag knobs (FB de-prioritises hashtag-heavy posts) ──
HASHTAGS_FB_ENABLED=false
HASHTAGS_TIKTOK_ENABLED=true
