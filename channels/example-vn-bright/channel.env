# ─────────────────────────────────────────────────────────────────────────
# Example VN AI-News channel — bright editorial variant. Pair the same
# Vietnamese voice with a newspaper-style bright UI for analytical pieces.
# ─────────────────────────────────────────────────────────────────────────

# ── Identity ──
CHANNEL_NAME=KTB AI News (bright)
CHANNEL_HANDLE=@ktbainews
CHANNEL_WATERMARK=

AVATAR_FILENAME=

# ── Theme ──
THEME_VARIANT=bright
THEME_PRIMARY=#1d4ed8
THEME_ACCENT=#16a34a
THEME_BG=#fafafa
THEME_HIGHLIGHT=#dc2626
THEME_GOLD=#ca8a04

# ── Voice ──
# vi-VN-NamMinhNeural matches upstream news_editor — male broadcaster
# voice that reads at VTV / HTV pace with the canonical +35% rate.
VOICE_NAME=vi-VN-NamMinhNeural
VOICE_GENDER=male
VOICE_GENDER_POLICY=auto_by_topic

# ── Optional premium TTS providers (leave blank = use Edge TTS only) ──
# ELEVENLABS_VOICE_ID=
# GOOGLE_TTS_API_KEY=
# GOOGLE_TTS_VOICE=

# ── Promo outro (showcase mode) ──
# When true, composer appends a 3-5s brand line read at the end.
PROMO_ENABLED=false
PROMO_OUTRO_TEXT=
PROMO_OUTRO_VOICE=vi-VN-NamMinhNeural
# Match body NEWS rate (+35%) — upstream news_editor uses the same value.
PROMO_OUTRO_RATE=+35%

# ── Hashtag knobs (FB de-prioritises hashtag-heavy posts) ──
HASHTAGS_FB_ENABLED=false
HASHTAGS_TIKTOK_ENABLED=true